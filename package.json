{
  "name": "condukt",
  "version": "0.4.0",
  "description": "Composable AI agent workflow framework — execution, state, orchestration, runtimes, UI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/animeshkundu/condukt.git"
  },
  "keywords": [
    "pipeline",
    "workflow",
    "agent",
    "ai",
    "flow",
    "orchestration",
    "ui",
    "dashboard"
  ],
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "import": "./dist/state/index.js",
      "require": "./dist/state/index.js",
      "default": "./dist/state/index.js"
    },
    "./state/server": {
      "types": "./dist/state/server.d.ts",
      "import": "./dist/state/server.js",
      "require": "./dist/state/server.js",
      "default": "./dist/state/server.js"
    },
    "./bridge": {
      "types": "./dist/bridge/index.d.ts",
      "import": "./dist/bridge/index.js",
      "require": "./dist/bridge/index.js",
      "default": "./dist/bridge/index.js"
    },
    "./runtimes/copilot": {
      "types": "./dist/runtimes/copilot/index.d.ts",
      "import": "./dist/runtimes/copilot/index.js",
      "require": "./dist/runtimes/copilot/index.js",
      "default": "./dist/runtimes/copilot/index.js"
    },
    "./runtimes/mock": {
      "types": "./dist/runtimes/mock/index.d.ts",
      "import": "./dist/runtimes/mock/index.js",
      "require": "./dist/runtimes/mock/index.js",
      "default": "./dist/runtimes/mock/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "require": "./dist/ui/index.js",
      "default": "./dist/ui/index.js"
    },
    "./ui/core": {
      "types": "./dist/ui/core/index.d.ts",
      "import": "./dist/ui/core/index.js",
      "require": "./dist/ui/core/index.js",
      "default": "./dist/ui/core/index.js"
    },
    "./ui/graph": {
      "types": "./dist/ui/graph/index.d.ts",
      "import": "./dist/ui/graph/index.js",
      "require": "./dist/ui/graph/index.js",
      "default": "./dist/ui/graph/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js",
      "require": "./dist/theme/index.js",
      "default": "./dist/theme/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.js",
      "default": "./dist/utils/index.js"
    },
    "./ui/tool-display": {
      "types": "./dist/ui/tool-display/index.d.ts",
      "import": "./dist/ui/tool-display/index.js",
      "require": "./dist/ui/tool-display/index.js",
      "default": "./dist/ui/tool-display/index.js"
    },
    "./ui/style.css": "./dist/ui/style.css"
  },
  "files": [
    "dist",
    "ui/style.css"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').cpSync('node_modules/@xyflow/react/dist/style.css','dist/ui/style.css')\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@xyflow/react": ">=12",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@xyflow/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.14",
    "@xyflow/react": "^12.10.1",
    "clsx": "^2.1.1",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1"
  }
}
